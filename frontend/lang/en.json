    "hero": {
        "badge": "🚧 Service not yet active — Invite only access",
        "title": "Your Buddy in<br>data transformations",
        "subtitle": "Visual drag-and-drop mapper to connect databases, CSV/XML files, EDI/HL7 formats and APIs. Your Buddy transforms data — no code required.",
        "warning_title": "⚠️ Buddyliko is under development",
        "warning_text": "The service is not yet available to the public.<br>Uninvited registrations <strong style='color:var(--orange)'>will not be activated</strong> and accounts will be deleted.<br>Do not contact us to request access if you haven't received an invitation.",
        "cta": "Learn more ↓"
    },
    "features": {
        "title": "Everything you need to transform data",
        "subtitle": "A single platform for B2B data mapping, transformation and integration. Your Buddy does the heavy lifting.",
        "mapper": {
            "title": "Visual Mapper",
            "desc": "Drag-and-drop to connect source and destination fields. Supports nested structures, arrays and custom formulas."
        },
        "db": {
            "title": "Database Connector",
            "desc": "Connect directly to PostgreSQL, MySQL, SQL Server and SQLite. Read and write tables as source or destination."
        },
        "formats": {
            "title": "Multiple Formats",
            "desc": "CSV, JSON, XML, Excel, EDI X12/EDIFACT, HL7. Import, transform and export in any format."
        },
        "ai": {
            "title": "AI Auto-mapping",
            "desc": "Let your Buddy automatically map fields. Supports business rules and semantic inference."
        },
        "codegen": {
            "title": "Code Generation",
            "desc": "Generate Python, JavaScript or XSLT code from your mappings. Run transformations in your own environment."
        },
        "collab": {
            "title": "Collaboration",
            "desc": "Shared workspace with groups, permissions and full audit log for teams and organizations."
        }
    },
    "usecases": {
        "title": "Use Cases",
        "subtitle": "Buddyliko solves real B2B data transformation challenges.",
        "sap": {
            "title": "SAP IDoc → UBL 2.1",
            "desc": "Transform SAP IDoc invoices (FA3, INVOIC) to UBL 2.1 format for PEPPOL European e-invoicing."
        },
        "fattura": {
            "title": "FatturaPA ↔ UBL PEPPOL",
            "desc": "Convert Italian FatturaPA (SDI) to UBL PEPPOL and vice versa. Regulatory compliance for cross-border exchange."
        },
        "edifact": {
            "title": "EDIFACT INVOIC",
            "desc": "Map EDIFACT D96A invoices to your ERP formats or to UBL for the PEPPOL network."
        },
        "multi": {
            "title": "Multi-country invoicing",
            "desc": "Handle e-invoicing requirements for Italy, France, Denmark, Poland and other EU countries with a single mapper."
        }
    },
