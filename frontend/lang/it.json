    "features": {
        "title": "Tutto ciò che serve per trasformare i dati",
        "subtitle": "Un'unica piattaforma per mapping, trasformazione e integrazione dati B2B. Il tuo Buddy fa il lavoro pesante.",
        "mapper": {
            "title": "Mapper visuale",
            "desc": "Drag-and-drop per collegare campi sorgente e destinazione. Supporta strutture nested, array e formule personalizzate."
        },
        "db": {
            "title": "Database Connector",
            "desc": "Collegati direttamente a PostgreSQL, MySQL, SQL Server e SQLite. Leggi e scrivi tabelle come sorgente o destinazione."
        },
        "formats": {
            "title": "Formati multipli",
            "desc": "CSV, JSON, XML, Excel, EDI X12/EDIFACT, HL7. Importa, trasforma ed esporta in qualsiasi formato."
        },
        "ai": {
            "title": "AI Auto-mapping",
            "desc": "Lascia che il tuo Buddy mappi automaticamente i campi. Supporta business rules e inferenza semantica."
        },
        "codegen": {
            "title": "Code Generation",
            "desc": "Genera codice Python, JavaScript o XSLT dalle tue mappature. Esegui le trasformazioni nel tuo ambiente."
        },
        "collab": {
            "title": "Collaborazione",
            "desc": "Workspace condiviso con gruppi, permessi e audit log completo per team e organizzazioni."
        }
    },
    "usecases": {
        "title": "Casi d'uso",
        "subtitle": "Buddyliko risolve problemi reali di trasformazione dati B2B.",
        "sap": {
            "title": "SAP IDoc → UBL 2.1",
            "desc": "Trasforma fatture SAP IDoc (FA3, INVOIC) in formato UBL 2.1 per la fatturazione elettronica europea PEPPOL."
        },
        "fattura": {
            "title": "FatturaPA ↔ UBL PEPPOL",
            "desc": "Converti FatturaPA (SDI italiano) in UBL PEPPOL e viceversa. Conformità normativa per lo scambio transfrontaliero."
        },
        "edifact": {
            "title": "EDIFACT INVOIC",
            "desc": "Mappa fatture EDIFACT D96A verso i formati del tuo gestionale o verso UBL per la rete PEPPOL."
        },
        "multi": {
            "title": "Fatturazione multi-paese",
            "desc": "Gestisci requisiti di fatturazione elettronica per Italia, Francia, Danimarca, Polonia e altri paesi EU con un unico mapper."
        }
    },
